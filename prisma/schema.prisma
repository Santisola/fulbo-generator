generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  password  String
  name      String?
  image     String?
  createdAt DateTime      @default(now())
  groups    GroupMember[]
  createdGroups Group[]
  ratings   Rating[]
}

model Group {
  id          String        @id @default(cuid())
  name        String
  code        String        @unique
  createdById String
  createdBy   User          @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  members     GroupMember[]
  players     Player[]
  teamHistory TeamHistory[]
}

model GroupMember {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  role      Role     @default(MEMBER)
  joinedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Player {
  id            String   @id @default(cuid())
  name          String
  groupId       String
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  ratings       Rating[]
  averageRating Float?
  createdAt     DateTime @default(now())

  @@index([groupId])
}

model Rating {
  id        String   @id @default(cuid())
  playerId  String
  userId    String
  score     Int
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([playerId, userId])
}

model TeamHistory {
  id            String   @id @default(cuid())
  groupId       String
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teamA         String   // JSON array of player IDs
  teamB         String   // JSON array of player IDs
  averageDiff   Float
  generatedAt   DateTime @default(now())

  @@index([groupId])
}

enum Role {
  ADMIN
  MEMBER
}
