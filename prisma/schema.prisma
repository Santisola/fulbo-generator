generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  password  String
  name      String?
  image     String?
  createdAt DateTime      @default(now())
  groups    GroupMember[]
  createdGroups Group[]
  ratings   Rating[]
}

model Group {
  id          String        @id @default(cuid())
  name        String
  code        String        @unique
  createdById String
  createdBy   User          @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  members     GroupMember[]
  players     Player[]
  teamHistory TeamHistory[]
  incompatibilities PlayerIncompatibility[]
}

model GroupMember {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  role      Role     @default(MEMBER)
  joinedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Player {
  id            String   @id @default(cuid())
  name          String
  groupId       String
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  ratings       Rating[]
  averageRating Float?
  createdAt     DateTime @default(now())
  incompatibilities1 PlayerIncompatibility[] @relation("incompatibilityPlayer1")
  incompatibilities2 PlayerIncompatibility[] @relation("incompatibilityPlayer2")

  @@index([groupId])
}

model Rating {
  id        String   @id @default(cuid())
  playerId  String
  userId    String
  score     Int
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([playerId, userId])
}

model TeamHistory {
  id            String   @id @default(cuid())
  groupId       String
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teamA         String   // JSON array of player IDs
  teamB         String   // JSON array of player IDs
  averageDiff   Float
  generatedAt   DateTime @default(now())

  @@index([groupId])
}

model PlayerIncompatibility {
  id         String   @id @default(cuid())
  groupId    String
  player1Id  String
  player2Id  String
  type       CompatibilityType @default(CANNOT_FACE_EACH_OTHER)
  reason     String?
  createdAt  DateTime @default(now())
  
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  player1    Player   @relation("incompatibilityPlayer1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2    Player   @relation("incompatibilityPlayer2", fields: [player2Id], references: [id], onDelete: Cascade)

  @@unique([groupId, player1Id, player2Id])
  @@index([groupId])
}

enum Role {
  ADMIN
  MEMBER
}

enum CompatibilityType {
  CANNOT_FACE_EACH_OTHER      // No pueden jugar enfrentados (equipos opuestos)
  MUST_BE_ON_SAME_TEAM        // Deben estar en el mismo equipo
}
